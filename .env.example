# --- Auth ---
# Sign-in is ON by default. AUTH_PROVIDER=local is a lightweight name/email
# sign-in (no password) used until real Google OAuth is wired up for Azure.
AUTH_ENABLED=true
AUTH_PROVIDER=local
# Comma-separated Gmail addresses that are auto-approved as admins on first sign-in
ADMIN_EMAILS=ppudot1@gmail.com
# Secret used to sign session JWTs — set a long random string
JWT_SECRET=change-me-to-a-long-random-string

# --- Google OAuth (Azure phase — leave blank for now) ---
# Setting this switches AUTH_PROVIDER to 'google' automatically
GOOGLE_CLIENT_ID=

# --- Extraction ---
# Anthropic API key for reading uploaded sheet PHOTOS (xlsx uploads don't need it)
ANTHROPIC_API_KEY=
# Vision model used for image extraction
CLAUDE_MODEL=claude-sonnet-5

# --- Server ---
PORT=3003
# Directory for SQLite DB + uploaded files. On Azure App Service use /home/data (persistent).
DATA_DIR=./data
NODE_ENV=development
