# --- Auth ---
# Google OAuth 2.0 Web client ID (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
# Comma-separated Gmail addresses that are auto-approved as admins
ADMIN_EMAILS=ppudot1@gmail.com
# Secret used to sign session JWTs — set a long random string in production
JWT_SECRET=

# --- Extraction ---
# Anthropic API key for reading uploaded sheet PHOTOS (xlsx uploads don't need it)
ANTHROPIC_API_KEY=
# Vision model used for image extraction
CLAUDE_MODEL=claude-sonnet-5

# --- Server ---
PORT=3001
# Directory for SQLite DB + uploaded files. On Azure App Service use /home/data (persistent).
DATA_DIR=./data
NODE_ENV=development
